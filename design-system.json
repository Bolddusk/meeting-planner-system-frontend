{
  "name": "Meeting Planner Design System",
  "version": "1.0.0",
  "description": "Shared design tokens for Admin Panel (web) and Mobile App. Keep both UIs in sync using these values.",
  "brand": {
    "appName": "Meeting Planner",
    "organization": "Government of Pakistan",
    "tagline": "Schedule, manage, and track government meetings across departments."
  },
  "colors": {
    "primary": {
      "50": "#ecfdf5",
      "100": "#d1fae5",
      "200": "#a7f3d0",
      "300": "#6ee7b7",
      "400": "#34d399",
      "500": "#10b981",
      "600": "#059669",
      "700": "#047857",
      "800": "#065f46",
      "900": "#064e3b",
      "950": "#022c22"
    },
    "sidebar": {
      "background": "#0d5c3d",
      "hover": "#0a4a31",
      "active": "#147a52",
      "text": "#d1fae5",
      "textMuted": "rgba(167, 243, 208, 0.8)",
      "textActive": "#ffffff"
    },
    "neutral": {
      "background": "#f1f5f9",
      "surface": "#ffffff",
      "border": "#e2e8f0",
      "borderLight": "#f1f5f9",
      "textPrimary": "#1e293b",
      "textSecondary": "#475569",
      "textMuted": "#64748b",
      "textDisabled": "#94a3b8",
      "slate50": "#f8fafc",
      "slate100": "#f1f5f9",
      "slate200": "#e2e8f0",
      "slate300": "#cbd5e1",
      "slate400": "#94a3b8",
      "slate500": "#64748b",
      "slate600": "#475569",
      "slate700": "#334155",
      "slate800": "#1e293b",
      "slate900": "#0f172a"
    },
    "semantic": {
      "success": "#059669",
      "successLight": "#d1fae5",
      "successText": "#065f46",
      "warning": "#d97706",
      "warningLight": "#fef3c7",
      "warningText": "#92400e",
      "error": "#dc2626",
      "errorLight": "#fee2e2",
      "errorText": "#991b1b",
      "info": "#2563eb",
      "infoLight": "#dbeafe",
      "infoText": "#1e40af"
    },
    "gradients": {
      "hero": ["#065f46", "#047857"],
      "loginPanel": ["#064e3b", "#065f46", "#047857"]
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Segoe UI, system-ui, -apple-system, BlinkMacSystemFont, sans-serif",
      "sansMobile": "System"
    },
    "fontSize": {
      "xs": 12,
      "sm": 14,
      "base": 16,
      "lg": 18,
      "xl": 20,
      "2xl": 24,
      "3xl": 30,
      "4xl": 36
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.625
    },
    "letterSpacing": {
      "eyebrow": 0.2,
      "wide": 0.05
    },
    "styles": {
      "pageTitle": { "fontSize": 24, "fontWeight": "700", "color": "#ffffff" },
      "sectionTitle": { "fontSize": 18, "fontWeight": "600", "color": "#1e293b" },
      "cardTitle": { "fontSize": 16, "fontWeight": "600", "color": "#1e293b" },
      "body": { "fontSize": 14, "fontWeight": "400", "color": "#475569" },
      "bodySmall": { "fontSize": 12, "fontWeight": "400", "color": "#64748b" },
      "eyebrow": { "fontSize": 10, "fontWeight": "600", "textTransform": "uppercase", "letterSpacing": 0.2, "color": "#a7f3d0" },
      "label": { "fontSize": 14, "fontWeight": "500", "color": "#334155" },
      "input": { "fontSize": 14, "fontWeight": "400", "color": "#1e293b" }
    }
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64,
    "screenPadding": 16,
    "cardPadding": 24,
    "sectionGap": 24
  },
  "borderRadius": {
    "sm": 6,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "2xl": 20,
    "full": 9999
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)",
    "card": "0 1px 3px 0 rgba(0, 0, 0, 0.08)"
  },
  "components": {
    "button": {
      "borderRadius": 12,
      "height": { "sm": 36, "md": 40, "lg": 44 },
      "paddingHorizontal": { "sm": 12, "md": 16, "lg": 20 },
      "variants": {
        "primary": { "background": "#047857", "text": "#ffffff", "backgroundPressed": "#065f46" },
        "secondary": { "background": "#ffffff", "text": "#065f46", "border": "#a7f3d0", "backgroundPressed": "#ecfdf5" },
        "ghost": { "background": "transparent", "text": "#475569", "backgroundPressed": "#f1f5f9" },
        "danger": { "background": "#dc2626", "text": "#ffffff", "backgroundPressed": "#b91c1c" }
      }
    },
    "input": {
      "height": 44,
      "borderRadius": 12,
      "borderColor": "#cbd5e1",
      "borderColorFocus": "#047857",
      "background": "#ffffff",
      "placeholderColor": "#94a3b8",
      "paddingHorizontal": 12
    },
    "card": {
      "background": "#ffffff",
      "borderRadius": 16,
      "borderColor": "#e2e8f0",
      "padding": 24
    },
    "badge": {
      "borderRadius": 9999,
      "paddingHorizontal": 10,
      "paddingVertical": 2,
      "fontSize": 12,
      "variants": {
        "default": { "background": "#f1f5f9", "text": "#334155" },
        "success": { "background": "#d1fae5", "text": "#065f46" },
        "warning": { "background": "#fef3c7", "text": "#92400e" },
        "info": { "background": "#dbeafe", "text": "#1e40af" },
        "danger": { "background": "#fee2e2", "text": "#991b1b" },
        "primary": { "background": "#d1fae5", "text": "#065f46" }
      }
    },
    "pageHero": {
      "borderRadius": 16,
      "gradient": ["#065f46", "#047857"],
      "padding": 28,
      "titleColor": "#ffffff",
      "descriptionColor": "#d1fae5"
    },
    "tabBar": {
      "background": "#ffffff",
      "activeColor": "#047857",
      "inactiveColor": "#94a3b8",
      "borderTop": "#e2e8f0"
    },
    "header": {
      "background": "#ffffff",
      "titleColor": "#1e293b",
      "borderBottom": "#e2e8f0"
    }
  },
  "status": {
    "meeting": {
      "SCHEDULED": { "badge": "info", "color": "#2563eb", "background": "#dbeafe" },
      "RESCHEDULED": { "badge": "warning", "color": "#f97316", "background": "#ffedd5" },
      "IN_PROGRESS": { "badge": "success", "color": "#22c55e", "background": "#dcfce7" },
      "COMPLETED": { "badge": "default", "color": "#6b7280", "background": "#f3f4f6" },
      "CANCELLED": { "badge": "danger", "color": "#ef4444", "background": "#fee2e2" }
    },
    "rsvp": {
      "PENDING": { "badge": "warning", "color": "#d97706", "background": "#fef3c7" },
      "ACCEPTED": { "badge": "success", "color": "#059669", "background": "#d1fae5" },
      "DECLINED": { "badge": "danger", "color": "#dc2626", "background": "#fee2e2" },
      "TENTATIVE": { "badge": "warning", "color": "#d97706", "background": "#fef3c7" }
    },
    "actionItem": {
      "OPEN": { "badge": "warning", "color": "#d97706", "background": "#fef3c7" },
      "DONE": { "badge": "success", "color": "#059669", "background": "#d1fae5" }
    },
    "export": {
      "QUEUED": { "badge": "default", "color": "#64748b", "background": "#f1f5f9" },
      "PROCESSING": { "badge": "info", "color": "#2563eb", "background": "#dbeafe" },
      "READY": { "badge": "success", "color": "#059669", "background": "#d1fae5" },
      "FAILED": { "badge": "danger", "color": "#dc2626", "background": "#fee2e2" }
    }
  },
  "icons": {
    "library": "Lucide (web) / equivalent outline icons on mobile",
    "strokeWidth": 2,
    "sizes": { "sm": 16, "md": 20, "lg": 24, "xl": 32 }
  },
  "layout": {
    "adminMinWidth": 1024,
    "mobileScreenPadding": 16,
    "maxContentWidth": 1280,
    "sidebarWidth": 256,
    "sidebarCollapsedWidth": 72
  }
}
