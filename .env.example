# Base URL of the backend API (include the /api suffix).
# IMPORTANT: This is a Vite variable — it is inlined into the built bundle
# at BUILD time, so in production it must be supplied as a build argument,
# not a runtime environment variable.
VITE_API_URL=http://localhost:5000/api

# App display name
VITE_APP_NAME=Meeting Planner Admin

# Leave false in production. When true, enables a mock auth flow for local dev.
VITE_USE_MOCK_AUTH=false
